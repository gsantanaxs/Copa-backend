{
  "version": 2,
  "name": "fifa2026-guide",
  "builds": [
    {
      "src": "frontend/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/css/**",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/js/**",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/lib/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/login",
      "dest": "/frontend/login.html"
    },
    {
      "src": "/avaliar",
      "dest": "/frontend/avaliar.html"
    },
    {
      "src": "/buscar",
      "dest": "/frontend/buscar.html"
    },
    {
      "src": "/perfil",
      "dest": "/frontend/perfil.html"
    },
    {
      "src": "/css/(.*)",
      "dest": "/frontend/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/frontend/js/$1"
    },
    {
      "src": "/lib/(.*)",
      "dest": "/frontend/lib/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
